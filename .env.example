# 복사해서 .env 로 사용 (.env 는 절대 커밋 금지)

# --- App ---
APP_NAME=Azure ML Backend
ENVIRONMENT=development
LOG_LEVEL=INFO

# --- Auth ---
# 클라이언트가 X-API-Key 헤더로 보내야 하는 값
API_KEY=change-me-local-key

# --- ML client ---
# mock = 내부 스텁(기본), azure = 실제 Azure ML 엔드포인트
ML_CLIENT=mock
AZURE_ML_SCORING_URI=
# 엔드포인트 단위 인증 키(primary/secondary). 워크스페이스 단일 키가 아니라
# 해당 엔드포인트 Consume 탭에서 확보. 호출엔 primary 우선·secondary 폴백. 절대 커밋 금지.
AZURE_ML_AUTH_PRI_KEY=
AZURE_ML_AUTH_SEC_KEY=
ML_TIMEOUT_CONNECT=5.0
ML_TIMEOUT_READ=30.0
ML_MAX_RETRIES=2

# --- CORS (콤마 구분, 비우면 비활성) ---
CORS_ORIGINS=

# --- Rate limit ---
RATE_LIMIT_ENABLED=true
RATE_LIMIT=60/minute

# --- (참고: 현재 미사용) GitHub OAuth App / Easy Auth ---
# oauth_client_secret_key=
